# نموذج ملف البيئة — انسخه إلى .env واملأ القيم
# هذا الملف مطلوب كأصل (asset) في pubspec.yaml ويجب أن يوجد وقت البناء.

# مفتاح تشفير Realm المحلي (64 بايت بصيغة hex = 128 حرفاً)
# لتوليد مفتاح جديد:  openssl rand -hex 64
# تحذير: لا تغيّر هذا المفتاح بعد إطلاق التطبيق، وإلا لن يستطيع قراءة قواعد البيانات الحالية.
REALM_ENCRYPTION_KEY=your_64_byte_hex_key_here
